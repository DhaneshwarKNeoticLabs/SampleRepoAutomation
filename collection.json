          "listen": "prerequest",
          "script": {
            "exec": [
              "let chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz\";\r",
              "let randomUOM = \"\";\r",
